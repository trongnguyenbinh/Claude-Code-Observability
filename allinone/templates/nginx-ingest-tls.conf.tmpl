# INGEST vhost with in-container TLS (all-in-one, TLS_ENABLED=true).
# Mount your cert + key and set TLS_CERT / TLS_KEY. A plain :80 redirect is added too.

server {
    listen 80;
    listen [::]:80;
    server_name ${OTEL_DOMAIN};
    location / { return 301 https://$host$request_uri; }
}

server {
    listen ${INGEST_PORT} ssl;
    listen [::]:${INGEST_PORT} ssl;
    server_name ${OTEL_DOMAIN};

    ssl_certificate     ${TLS_CERT};
    ssl_certificate_key ${TLS_KEY};

    client_max_body_size 16m;

    location /v1/ {
        if ($otel_device = "") { return 401; }
        proxy_pass http://127.0.0.1:4318;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Otel-Device $otel_device;
    }

    location = /healthz { return 200 "ok\n"; add_header Content-Type text/plain; }
    location / { return 404; }
}
